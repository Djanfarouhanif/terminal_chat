# ============================================================================
#  Configuration de PRODUCTION — copiez en .env.prod et remplissez.
#  NE JAMAIS committer .env.prod (déjà ignoré par .gitignore/.dockerignore).
# ============================================================================

# --- Django ---
# Générez une clé : python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGEZ_MOI_cle_longue_et_aleatoire
DEBUG=False
ALLOWED_HOSTS=chat.example.com
CSRF_TRUSTED_ORIGINS=https://chat.example.com

# Activez HSTS une fois que HTTPS fonctionne (1 an) : 31536000
SECURE_HSTS_SECONDS=0

# --- PostgreSQL (POSTGRES_HOST est fixé à "postgres" par le compose) ---
POSTGRES_DB=hanif
POSTGRES_USER=hanif
POSTGRES_PASSWORD=CHANGEZ_MOI_mot_de_passe_fort
POSTGRES_PORT=5432

# --- Redis (REDIS_HOST est fixé à "redis" par le compose) ---
REDIS_PORT=6379

# --- JWT ---
ACCESS_TOKEN_LIFETIME=30
REFRESH_TOKEN_LIFETIME=7
